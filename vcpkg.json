{
	"name": "drea",
	"version": "0.30.1",
	"dependencies": [
		"fmt",
		"spdlog",
		"boost-algorithm",
		"boost-beast",
		"yaml-cpp",
		"nlohmann-json",
		"uriparser",
		"tl-expected",
		"catch2"
	],
	"features": {
		"aws": {
			"description": "AWS Secrets Manager config source",
			"dependencies": [
				{
					"name": "aws-sdk-cpp",
					"default-features": false,
					"features": ["secretsmanager"]
				}
			]
		},
		"toml": {
			"description": "TOML config-file support (cpptoml)",
			"dependencies": ["cpptoml"]
		}
	}
}
